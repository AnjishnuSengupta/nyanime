# Security and Performance Headers for NyAnime
# Works with Netlify, Cloudflare Pages, and other platforms

/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  
  # Content Security Policy (adjust as needed)
  # Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data:; connect-src 'self' https://api.jikan.moe https://consumet.nyanime.qzz.io https://nyanime-backend-v2.onrender.com https://firebasestorage.googleapis.com; frame-src 'self' https://www.youtube.com; media-src 'self' https: blob:
  
  # Performance Headers
  Cache-Control: public, max-age=0, must-revalidate

# Cache static assets aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  Cache-Control: public, max-age=86400

/favicon.ico
  Cache-Control: public, max-age=86400

# API routes - no cache
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  
/aniwatch
  Cache-Control: no-cache, no-store, must-revalidate

# Sitemap and robots - cache for 1 day
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/manifest.json
  Cache-Control: public, max-age=86400
