# ============================================================================
# NyAnime Environment Configuration
# Complete list of all environment variables used in the project
# ============================================================================

# ============================================================================
# 🔥 FIREBASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get from: https://console.firebase.google.com/
# Navigate to: Project Settings → General → Your apps → Web app
#
# These 6 variables are REQUIRED for the app to work:

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENTID=


# ============================================================================
# 🎬 STREAMING PROVIDER CONFIGURATION
# ============================================================================
# Primary resolver: unofficial AnimeKAI REST API
# Fallback resolver: legacy /aniwatch-compatible endpoint
#
# Production (recommended): https://animekai.nyanime.tech
# Note: if this API is unhealthy, NyAnime will fall back to /aniwatch flow.
VITE_ANIMEKAI_UNOFFICIAL_API_URL=https://animekai.nyanime.tech

# Optional legacy fallback host for direct server-side proxy fallbacks.
# Keep this only if you run/maintain a compatible /api/v2/hianime backend.
VITE_ANIWATCH_API_URL=https://nyanime-backend-v2.onrender.com

# ============================================================================
# 🌐 CORS PROXY CONFIGURATION
# ============================================================================
# Enable/disable CORS proxy (default: true)
VITE_USE_CORS_PROXY=true

# Custom CORS Proxy URL (optional)
# If empty, uses built-in fallbacks: allorigins.win → corsproxy.io → codetabs.com
VITE_CORS_PROXY_URL=

# ============================================================================
# 📺 ANIME DATA APIs (Optional - have working defaults)
# ============================================================================

# Consumet API - Alternative anime source
# Default: https://api.consumet.org
VITE_CONSUMET_API_URL=https://api.consumet.org

# MyAnimeList/Jikan API - Anime metadata and information
# Default: https://api.jikan.moe/v4
VITE_JIKAN_API_KEY=https://api.jikan.moe/v4

# GoGoAnime API URL (via Consumet)
# Default: https://api.consumet.org/anime/gogoanime
VITE_GOGOANIME_API_KEY=https://api.consumet.org/anime/gogoanime

# AnimePahe API URL (via Consumet)
# Default: https://api.consumet.org/anime/animepahe
VITE_ANIMEPAHE_API_KEY=https://api.consumet.org/anime/animepahe

# AniList GraphQL API
# Default: https://graphql.anilist.co
VITE_ANILIST_API_URL=https://graphql.anilist.co

# ============================================================================
# 🔑 THIRD-PARTY API KEYS (Optional)
# ============================================================================

# YouTube Data API v3 Key (for fetching anime trailers)
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
# Used in: src/services/animeService.ts
VITE_YOUTUBE_API_KEY=

# TMDB (The Movie Database) API Key
# Get from: https://www.themoviedb.org/settings/api
# Used for: Additional metadata and images (currently unused in code)
VITE_TMDB_API_KEY=

# Google reCAPTCHA Site Key (for bot protection)
# Get from: https://www.google.com/recaptcha/admin
# Used in: src/config/apiConfig.ts
VITE_RECAPTCHA_SITE_KEY=

# ============================================================================
# ⚙️ APP CONFIGURATION (Optional - have defaults)
# ============================================================================

# Application name
VITE_APP_NAME=NyAnime

# Application version
VITE_APP_VERSION=0.0.1

# API rate limiting (requests per minute for Jikan API)
# Default: 60
VITE_API_RATE_LIMIT=60

# ============================================================================
# 📋 ENVIRONMENT VARIABLES SUMMARY
# ============================================================================
#
# REQUIRED (App won't work without these):
#   ✅ VITE_FIREBASE_API_KEY
#   ✅ VITE_FIREBASE_AUTH_DOMAIN
#   ✅ VITE_FIREBASE_PROJECT_ID
#   ✅ VITE_FIREBASE_STORAGE_BUCKET
#   ✅ VITE_FIREBASE_MESSAGING_SENDER_ID
#   ✅ VITE_FIREBASE_APP_ID
#
# RECOMMENDED (Uses production defaults):
#   ⭐ VITE_ANIMEKAI_UNOFFICIAL_API_URL (AnimeKAI primary API)
#   ⭐ VITE_USE_CORS_PROXY (defaults to true)
#
# OPTIONAL (App works without these):
#   ⚪ VITE_CORS_PROXY_URL (has built-in fallbacks)
#   ⚪ VITE_CONSUMET_API_URL (has default)
#   ⚪ VITE_JIKAN_API_KEY (has default)
#   ⚪ VITE_GOGOANIME_API_KEY (has default)
#   ⚪ VITE_ANIMEPAHE_API_KEY (has default)
#   ⚪ VITE_ANILIST_API_URL (has default)
#   ⚪ VITE_YOUTUBE_API_KEY (trailers still work via Jikan)
#   ⚪ VITE_TMDB_API_KEY (not currently used)
#   ⚪ VITE_RECAPTCHA_SITE_KEY (optional security)
#   ⚪ VITE_APP_NAME (has default)
#   ⚪ VITE_APP_VERSION (has default)
#   ⚪ VITE_API_RATE_LIMIT (has default)
#
# ============================================================================
# 🚀 QUICK START
# ============================================================================
# 1. Add your Firebase credentials above (6 VITE_FIREBASE_* variables)
# 2. Save this file
# 3. Run: npm install && npm run dev
# 4. App should work! 🎉
#
# For deployment to Vercel/Cloudflare:
# - Add all these variables in the dashboard
# - Never commit this .env file to Git
# ============================================================================

# ============================================================================
# 📍 WHERE THESE VARIABLES ARE USED
# ============================================================================
# FIREBASE_*: src/config/firebase.ts, src/config/apiConfig.ts
# ANIMEKAI_UNOFFICIAL_API_URL: src/services/aniwatchApiService.ts, src/main.tsx
# ANIWATCH_API_URL: server.js fallback proxy + src/config/apiConfig.ts
# CORS_PROXY_*: src/services/aniwatchApiService.ts
# CONSUMET_API_URL: src/lib/consumet/client.ts, src/config/apiConfig.ts
# JIKAN_API_KEY: src/config/apiConfig.ts
# GOGOANIME/ANIMEPAHE/ANILIST: Referenced in consumet services
# YOUTUBE_API_KEY: src/services/animeService.ts (line 70, 199-217)
# API_RATE_LIMIT: src/services/animeService.ts (line 73)
# RECAPTCHA_SITE_KEY: src/config/apiConfig.ts
# APP_*: src/config/apiConfig.ts
# ============================================================================
